@extends('layouts.app')

@section('content')
<h2>Kasir</h2>

<div class="row">
    <div class="col-md-6">
        <div class="card mb-3">
            <div class="card-body">
                <label>Scan Barcode:</label>
                <input type="text" id="barcodeInput" class="form-control" placeholder="Scan / ketik barcode">
            </div>
        </div>

        <table class="table table-bordered" id="cartTable">
            <thead>
                <tr>
                    <th>Barang</th>
                    <th>Qty</th>
                    <th>Harga</th>
                    <th>Subtotal</th>
                </tr>
            </thead>
            <tbody></tbody>
        </table>

        <div class="d-flex justify-content-between align-items-center">
            <h4>Total: Rp<span id="totalPrice">0</span></h4>
            <button id="payBtn" class="btn btn-success">Bayar</button>
        </div>
    </div>
</div>

<script>
let cart = [];
let total = 0;

document.getElementById('barcodeInput').addEventListener('keypress', function(e){
    if(e.key === 'Enter'){
        const barcode = this.value.trim();
        axios.get(`/api/variant/${barcode}`)
        .then(res => {
            const item = res.data;
            addToCart(item);
            this.value = '';
        })
        .catch(err => alert(err.response.data.error || 'Barang tidak ditemukan'));
    }
});

function addToCart(item){
    const existing = cart.find(i => i.id === item.id);
    if(existing){
        existing.qty++;
    } else {
        cart.push({id:item.id, name:item.variant_name, price:item.price, discount:item.discount, qty:1});
    }
    renderCart();
}

function renderCart(){
    const tbody = document.querySelector('#cartTable tbody');
    tbody.innerHTML = '';
    total = 0;

    cart.forEach(i => {
        const subtotal = i.qty * i.price * (1 - (i.discount/100));
        total += subtotal;
        tbody.innerHTML += `
            <tr>
                <td>${i.name}</td>
                <td>${i.qty}</td>
                <td>Rp${i.price}</td>
                <td>Rp${subtotal.toFixed(0)}</td>
            </tr>
        `;
    });
    document.getElementById('totalPrice').textContent = total.toFixed(0);
}

document.getElementById('payBtn').addEventListener('click', function(){
    if(cart.length === 0) return alert('Keranjang kosong!');
    const paymentMethod = prompt('Metode pembayaran (tunai/debit):','tunai');
    const paid = parseInt(prompt('Jumlah dibayar:'));

    axios.post('/pos/checkout', {
        items: cart.map(i => ({variant_id:i.id, quantity:i.qty})),
        payment_method: paymentMethod,
        paid_amount: paid
    }).then(res => {
        alert('Transaksi berhasil!');
        window.open(`/pos/receipt/${res.data.sale_id}`,'_blank');
        cart = []; renderCart();
    }).catch(err => alert(err.response.data.error));
});
</script>
@endsection
